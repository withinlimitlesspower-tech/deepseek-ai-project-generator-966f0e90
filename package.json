{
  "name": "deepseek-v3-2-project-generator",
  "version": "5.5.0",
  "description": "AI Project Generator V5.5 - Complete project generation and conversation system",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "build": "node scripts/build.js",
    "clean": "rm -rf dist && rm -rf coverage",
    "security-check": "npm audit",
    "generate-project": "node src/generators/projectGenerator.js",
    "generate-blueprint": "node src/generators/blueprintGenerator.js",
    "validate-config": "node src/validators/configValidator.js"
  },
  "keywords": [
    "ai",
    "project-generator",
    "deepseek",
    "full-stack",
    "automation",
    "code-generation"
  ],
  "author": "DeepSeek V3.2 AI Assistant",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.0.3",
    "winston": "^3.8.2",
    "joi": "^17.9.2",
    "uuid": "^9.0.0",
    "axios": "^1.4.0",
    "chalk": "^5.2.0",
    "inquirer": "^9.2.7",
    "fs-extra": "^11.1.1",
    "glob": "^10.2.6",
    "handlebars": "^4.7.7",
    "marked": "^5.0.2",
    "highlight.js": "^11.8.0",
    "yaml": "^2.3.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "rate-limiter-flexible": "^3.0.8",
    "express-validator": "^6.15.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.1",
    "socket.io": "^4.6.1",
    "redis": "^4.6.7",
    "mongoose": "^7.3.0",
    "sequelize": "^6.32.0",
    "pg": "^8.11.0",
    "mysql2": "^3.5.0",
    "sqlite3": "^5.1.6",
    "prisma": "^5.0.0",
    "graphql": "^16.7.0",
    "apollo-server-express": "^3.12.0",
    "swagger-ui-express": "^4.6.3",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.0",
    "supertest": "^6.3.3",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "prettier": "^3.0.0",
    "@types/node": "^20.4.5",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "babel-jest": "^29.6.0",
    "@babel/core": "^7.22.9",
    "@babel/preset-env": "^7.22.9",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deepseek-ai/project-generator-v5.5.git"
  },
  "bugs": {
    "url": "https://github.com/deepseek-ai/project-generator-v5.5/issues"
  },
  "homepage": "https://github.com/deepseek-ai/project-generator-v5.5#readme",
  "private": false,
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/**/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "setupFilesAfterEnv": [
      "./src/tests/setup.js"
    ]
  },
  "browserslist": [
    "node >= 18"
  ],
  "volta": {
    "node": "18.16.0"
  }
}